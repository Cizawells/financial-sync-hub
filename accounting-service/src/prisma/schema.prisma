generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Customer {
  id        Int      @id @default(autoincrement())
  first_name      String
  last_name      String
  email     String?   @unique
  address  String?
  currency String?
  payment_terms String?
  qb_customer_id String?
  billing_address String?
  shipping_address String?
  tax_exempt Boolean?
  balance Decimal? @db.Decimal(10, 2)
  created_at DateTime?
  updated_at DateTime?
}