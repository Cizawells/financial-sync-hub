// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Customer {
  id        String      @id @default(uuid())
  first_name      String
  last_name      String
  email     String?   @unique
  address  String?
  currency String?
  payment_terms String?
  qb_id String?
  billing_address String?
  shipping_address String?
  city String?
  country String?
  phone String?
  tax_exempt Boolean?
  balance Decimal? @db.Decimal(10, 2)
  qb_sync_token String?
  active Boolean @default(true)
  deleted_at DateTime?
  created_at DateTime?
  updated_at DateTime?

  @@unique([created_at, id])
  @@map("customers")

  invoices Invoice[]
}

model Product {
  id          String   @id @default(uuid())
  
  name        String @unique
  description String?
  sku         String?  @unique  // stock keeping unit
  type        ProductType @default(Inventory)
  unit_price  Decimal  @db.Decimal(10, 2)
  cost        Decimal? @db.Decimal(10, 2)  // purchase cost
  quantity_on_hand  Int     @default(0)
  inventory_start_date DateTime?
  reorder_point     Int?    // alert when stock drops below this
  taxable     Boolean  @default(true)
  qb_id         String?  @unique
  qb_sync_token String?
  active      Boolean   @default(true)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@unique([created_at, id])

  invoice_items InvoiceItem[]  

  @@map("products")
}

model InvoiceItem {
  id  String @id @default(uuid())
  invoice_id String
  product_id  String
  quantity Int @default(1)
  unit_price Decimal @db.Decimal(10, 2) 
  tax_rate Int?
  line_total Decimal @db.Decimal(10, 2) 
  discount_amount Decimal? @db.Decimal(10, 2)
  discount_percent Int?

  @@map("invoice_items")

  invoice Invoice @relation(fields: [invoice_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

}

model Invoice {
  id  String @id @default(uuid())
  customer_id String
  invoice_date  DateTime
  due_date  DateTime
  status  InvoiceStatus?
  total_amount  Decimal @db.Decimal(10, 2) 
  notes String?
  qb_id String? @unique()
  qb_sync_token String?
  subtotal  Decimal @db.Decimal(10, 2) 
  tax_amount  Decimal? @db.Decimal(10, 2) 
  discount  Int?
  currency  String?
  sync_status SYNCSTATUS?

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  customer   Customer   @relation(fields: [customer_id], references: [id])
  invoice_items InvoiceItem[] 

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
  OVERDUE
}

enum SYNCSTATUS {
  SYNCED
  NOTSYNCED
  FAILED
}

enum ProductType {
  Inventory      // physical product, tracks quantity
  NonInventory  // physical but not tracked (e.g. office supplies)
  Service        // services like consulting, labor
}

model SyncLog {
  id           String   @id @default(uuid())
  entity_type  String   // 'customer'
  entity_id    String   // your internal customer id
  action       String   // 'create' | 'update' | 'delete'
  status       String   @default("pending") // 'pending' | 'success' | 'failed'
  qb_id        String?
  direction    String?  @default("from_erp")
  error        String?
  attempts     Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("sync_logs")
}

model QbToken {
  id            Int      @id @default(1) // single row, always id=1
  access_token  String
  refresh_token String
  expires_at    DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("qb_tokens")
}