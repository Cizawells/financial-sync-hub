// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Customer {
  id        String      @id @default(uuid())
  first_name      String
  last_name      String
  email     String?   @unique
  address  String?
  currency String?
  payment_terms String?
  qb_id String?
  billing_address String?
  shipping_address String?
  city String?
  country String?
  phone String?
  tax_exempt Boolean?
  balance Decimal? @db.Decimal(10, 2)
  qb_sync_token String?
  active Boolean @default(true)
  deleted_at DateTime?
  created_at DateTime?
  updated_at DateTime?

  @@unique([created_at, id])
  @@map("customers")
}

model Product {
  id          String   @id @default(uuid())
  
  // Basic info
  name        String @unique
  description String?
  sku         String?  @unique  // stock keeping unit
  
  // Type — mirrors QuickBooks item types
  type        ProductType @default(Inventory)
  
  // Pricing
  unit_price  Decimal  @db.Decimal(10, 2)
  cost        Decimal? @db.Decimal(10, 2)  // purchase cost
  
  // Inventory tracking (only relevant for INVENTORY type)
  quantity_on_hand  Int     @default(0)
  reorder_point     Int?    // alert when stock drops below this

  // Tax
  taxable     Boolean  @default(true)

  // QuickBooks sync
  qb_id         String?  @unique
  qb_sync_token String?

  // Soft delete
  active      Boolean   @default(true)
  deleted_at  DateTime?

  // Timestamps
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@unique([created_at, id])

  // Relations
  // invoice_items InvoiceItem[]  // products will appear in invoice lines

  @@map("products")
}

enum ProductType {
  Inventory      // physical product, tracks quantity
  NonInventory  // physical but not tracked (e.g. office supplies)
  Service        // services like consulting, labor
}

model SyncLog {
  id           String   @id @default(uuid())
  entity_type  String   // 'customer'
  entity_id    String   // your internal customer id
  action       String   // 'create' | 'update' | 'delete'
  status       String   @default("pending") // 'pending' | 'success' | 'failed'
  qb_id        String?
  direction    String?  @default("from_erp")
  error        String?
  attempts     Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("sync_logs")
}